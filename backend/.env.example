# 专注力星球 - 环境配置示例
# 复制此文件为 .env 并填写实际值

# 服务器配置
PORT=3000
NODE_ENV=production

# DeepSeek API配置
# 请访问 https://platform.deepseek.com 获取API密钥
DEEPSEEK_API_KEY=your_api_key_here

# 允许的跨域来源（多个用逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# 会话配置
SESSION_SECRET=your_session_secret_here
