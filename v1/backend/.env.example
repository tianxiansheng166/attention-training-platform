# 专注力星球 v1.6 - 环境配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# ⚠️ 重要安全配置（生产环境必须设置）
# ============================================

# 服务器配置
PORT=3000
NODE_ENV=development

# DeepSeek API配置
# 请访问 https://platform.deepseek.com 获取API密钥
DEEPSEEK_API_KEY=your_api_key_here

# ============================================
# 安全配置
# ============================================

# JWT密钥 ⚠️ 生产环境必须设置，且长度至少32字符
JWT_SECRET=your_jwt_secret_here_min_32_chars_long_enough
JWT_EXPIRES_IN=7d

# 允许的跨域来源（多个用逗号分隔）
# ⚠️ 生产环境必须配置，防止CSRF攻击
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-production-domain.com

# ============================================
# 数据库配置
# ============================================

# SQLite配置（开发环境）
DB_DIALECT=sqlite

# PostgreSQL配置（生产环境）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=attention_training
# DB_USER=postgres
# DB_PASSWORD=your_db_password_here

# ============================================
# 可选配置
# ============================================

# 家长手机号绑定（阿里云短信）
# 如不使用短信功能，可留空
# ALIYUN_ACCESS_KEY_ID=your_access_key
# ALIYUN_ACCESS_KEY_SECRET=your_access_secret
# ALIYUN_SMS_SIGN_NAME=专注力星球
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxx
